<Window x:Class="app2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:app2"
        mc:Ignorable="d"
        Title="RSA Шифрование" Height="650" Width="831">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Ключи -->
        <GroupBox Grid.Row="0" Header="Ключи RSA (N=51 цифр)" Margin="0,0,0,10">
            <StackPanel Margin="5">
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <TextBox x:Name="tbPublicKey" IsReadOnly="True" Text="e, N (открытый)" Width="300" Margin="0,0,10,0"/>
                    <TextBox x:Name="tbPrivateKey" IsReadOnly="True" Text="d, N (закрытый)" Width="300"/>
                    <Button x:Name="btnGenerateKeys" Content="Генерировать ключи" Click="BtnGenerateKeys_Click" Margin="10,0,0,0" Padding="10,5"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Исходный текст -->
        <GroupBox Grid.Row="1" Header="Исходный текст (ASCII)" Margin="0,0,0,10">
            <StackPanel>
                <TextBox x:Name="tbInputText" AcceptsReturn="True" TextWrapping="Wrap" Height="60" Margin="5"/>
                <StackPanel Orientation="Horizontal" Margin="5,0">
                    <Button x:Name="btnClearInput" Content="Очистить" Click="BtnClearInput_Click" Padding="10,5"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Шифрование -->
        <GroupBox Grid.Row="2" Header="Шифрование" Margin="0,0,0,10">
            <StackPanel>
                <TextBox x:Name="tbEncrypted" IsReadOnly="True" TextWrapping="Wrap" Height="80" Margin="5"/>
                <TextBlock x:Name="lblEncryptTime" Text="Время: --" Margin="5,0,5,5"/>
            </StackPanel>
        </GroupBox>

        <!-- Кнопки операций -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            <Button x:Name="btnEncrypt" Content="Шифровать" Width="118" Click="BtnEncrypt_Click" Margin="0,0,10,0" Padding="10,5"/>
            <Button x:Name="btnDecrypt" Content="Расшифровать" Width="122" Click="BtnDecrypt_Click" Padding="10,5"/>
        </StackPanel>

        <!-- Расшифровка -->
        <GroupBox Grid.Row="4" Header="Расшифрованный текст" Margin="0,0,0,10">
            <StackPanel>
                <TextBox x:Name="tbDecrypted" IsReadOnly="True" TextWrapping="Wrap" Height="80" Margin="5"/>
                <TextBlock x:Name="lblDecryptTime" Text="Время: --" Margin="5,0,5,5"/>
            </StackPanel>
        </GroupBox>

        <!-- Лог -->
        <GroupBox Grid.Row="6" Header="Лог" Margin="0,0,0,10">
            <TextBox x:Name="tbLog" IsReadOnly="True" TextWrapping="Wrap" Height="60" VerticalScrollBarVisibility="Auto"/>
        </GroupBox>
    </Grid>
</Window>