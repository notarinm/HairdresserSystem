<<Window x:Class="HairdresserSystemWPF.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация клиента" Height="550" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="📝 Регистрация нового клиента" FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="ФИО:" FontSize="14" Margin="0,5"/>
        <TextBox x:Name="txtFullName" Grid.Row="2" FontSize="14" Padding="8" Margin="0,5"/>

        <TextBlock Grid.Row="3" Text="Телефон:" FontSize="14" Margin="0,15,0,5"/>
        <TextBox x:Name="txtPhone" Grid.Row="4" FontSize="14" Padding="8" Margin="0,5"/>

        <TextBlock Grid.Row="5" Text="Email:" FontSize="14" Margin="0,15,0,5"/>
        <TextBox x:Name="txtEmail" Grid.Row="6" FontSize="14" Padding="8" Margin="0,5"/>

        <TextBlock Grid.Row="7" Text="Логин:" FontSize="14" Margin="0,15,0,5"/>
        <TextBox x:Name="txtLogin" Grid.Row="8" FontSize="14" Padding="8" Margin="0,5"/>

        <TextBlock Grid.Row="9" Text="Пароль:" FontSize="14" Margin="0,15,0,5"/>
        <PasswordBox x:Name="txtPassword" Grid.Row="10" FontSize="14" Padding="8" Margin="0,5"/>

        <Button x:Name="btnRegister" Grid.Row="11" Content="Зарегистрироваться" 
                Width="200" Height="40" FontSize="14" FontWeight="Bold" Margin="0,30"
                HorizontalAlignment="Center" Background="#27ae60" Foreground="White"
                Click="BtnRegister_Click">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
    </Window>