<<<Window x:Class="HairdresserSystemWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Парикмахерская Стиль - Вход" 
        Height="400" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2c3e50" CornerRadius="10" Margin="0,0,0,20" Padding="20">
            <TextBlock Text="Парикмахерская Стиль" 
                       FontSize="24" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <TextBlock Grid.Row="1" Text="Логин:" FontSize="14" Margin="0,5"/>
        <TextBox x:Name="txtLogin" Grid.Row="2" FontSize="14" Padding="8" Margin="0,5"/>

        <TextBlock Grid.Row="3" Text="Пароль:" FontSize="14" Margin="0,15,0,5"/>
        <PasswordBox x:Name="txtPassword" Grid.Row="4" FontSize="14" Padding="8" Margin="0,5"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30">
            <Button x:Name="btnLogin" Content="Войти" Width="120" Height="40" 
                    FontSize="14" Margin="0,0,15,0" Click="BtnLogin_Click"/>
            <Button x:Name="btnRegister" Content="Регистрация" Width="120" Height="40" 
                    FontSize="14" Margin="15,0,0,0" Click="BtnRegister_Click"/>
        </StackPanel>

        <TextBlock x:Name="lblStatus" Grid.Row="6" Text="Подключение к БД" 
                   FontSize="11" Foreground="Gray" HorizontalAlignment="Center" Margin="0,20"/>
    </Grid>
    </Window>