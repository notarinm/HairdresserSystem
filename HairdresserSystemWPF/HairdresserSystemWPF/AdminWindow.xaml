<Window x:Class="HairdresserSystemWPF.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Парикмахерская Стиль - Панель администратора" 
        Height="700" Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2c3e50" Padding="15" Margin="0,0,0,15">
            <TextBlock Text="👑 Панель администратора" 
                       FontSize="18" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- Вкладки -->
        <TabControl Grid.Row="1" Height="560" VerticalAlignment="Top" Grid.RowSpan="2">

            <!-- ==================== ВКЛАДКА 1: ОБЩЕЕ РАСПИСАНИЕ ==================== -->
            <TabItem Header="📅 Общее расписание">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Дата:" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <DatePicker x:Name="dpScheduleDate" Width="150"/>
                        <Button x:Name="btnShowSchedule" Content="Показать" Width="100" Height="30" Margin="10,0,0,0" 
                                Background="#3498db" Foreground="White" Click="BtnShowSchedule_Click"/>
                        <Button x:Name="btnCreateAppointment" Content="➕ Создать запись" Width="130" Height="30" Margin="10,0,0,0" 
                                Background="#28a745" Foreground="White" Click="BtnCreateAppointment_Click"/>

                        <Button x:Name="btnCancelAppointment" Content="❌ Отменить запись" Width="140" Height="30" Margin="10,0,0,0" 
                    Background="#dc3545" Foreground="White" Click="BtnCancelAppointment_Click"/>
                    </StackPanel>

                    <ListBox x:Name="lstGeneralSchedule" Grid.Row="1" FontSize="13"
                 DisplayMemberPath="DisplayText" SelectionMode="Single"/>

                    
                </Grid>
            </TabItem>

            <!-- ==================== ВКЛАДКА 2: УПРАВЛЕНИЕ УСЛУГАМИ ==================== -->
            <TabItem Header="✂️ Управление услугами">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок -->
                    <TextBlock Text="Добавление новой услуги" 
                               FontWeight="Bold" FontSize="14" 
                               Margin="0,0,0,15"
                               Foreground="#2c3e50"/>

                    <!-- Форма добавления услуги -->
                    <Border Grid.Row="1" Background="#f8f9fa" BorderBrush="#ddd" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Название услуги -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Название услуги:" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtServiceName" Grid.Row="1" Grid.Column="0" Padding="8" Margin="0,0,15,15" FontSize="13"/>

                            <!-- Цена -->
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Цена (руб):" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtServicePrice" Grid.Row="1" Grid.Column="1" Padding="8" Margin="0,0,0,15" FontSize="13"/>

                            <!-- Длительность -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Длительность (мин):" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtServiceDuration" Grid.Row="3" Grid.Column="0" Padding="8" Margin="0,0,15,0" FontSize="13"/>

                            <!-- Кнопка -->
                            <Button x:Name="btnAddService" Grid.Row="3" Grid.Column="1" Content="➕ Добавить услугу" 
                                    Width="160" Height="38" HorizontalAlignment="Left"
                                    Background="#28a745" Foreground="White" FontWeight="Bold"
                                    Click="BtnAddService_Click"/>
                        </Grid>
                    </Border>

                    <!-- Список услуг -->
                    <TextBlock Grid.Row="2" Text="Список услуг" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                    <ListBox x:Name="lstServices" Grid.Row="3" Margin="0,0,0,10" FontSize="13"
         DisplayMemberPath="DisplayText" SelectionMode="Single">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="10"/>
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="BorderBrush" Value="#ddd"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <!-- Кнопка удаления -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnDeleteService" Content="🗑️ Удалить выбранную услугу" 
                                Width="200" Height="35" Background="#dc3545" Foreground="White"
                                Click="BtnDeleteService_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ==================== ВКЛАДКА 3: УПРАВЛЕНИЕ МАСТЕРАМИ ==================== -->
            <TabItem Header="👨‍🔧 Управление мастерами">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок -->
                    <TextBlock Text="Добавление нового мастера" 
                               FontWeight="Bold" FontSize="14" 
                               Margin="0,0,0,15"
                               Foreground="#2c3e50"/>

                    <!-- Форма добавления мастера -->
                    <Border Grid.Row="1" Background="#f8f9fa" BorderBrush="#ddd" BorderThickness="1" Padding="15" Margin="0,0,0,30">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- ФИО -->
                            <TextBlock Grid.Row="0" Text="ФИО мастера:" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtMasterName" Padding="8" Margin="0,22,0,15" FontSize="13" Grid.RowSpan="2"/>

                            <!-- Телефон -->
                            <TextBlock Grid.Row="2" Text="Телефон:" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtMasterPhone" Grid.Row="3" Padding="8" Margin="0,5,606,10" FontSize="13"/>

                            <!-- Логин -->
                            <TextBlock Grid.Row="2" Text="Логин:" FontSize="13" FontWeight="SemiBold" Margin="259,9,347,22" Grid.RowSpan="2"/>
                            <TextBox x:Name="txtMasterLogin" Grid.Row="3" Padding="8" Margin="259,5,347,10" FontSize="13"/>

                            <!-- Пароль -->
                            <TextBlock Grid.Row="2" Text="Пароль:" FontSize="13" FontWeight="SemiBold" Margin="538,5,-8,50" Grid.RowSpan="2"/>
                            <PasswordBox x:Name="txtMasterPassword" Grid.Row="3" Padding="8" Margin="538,5,68,10" FontSize="13"/>

                            <!-- Кнопка -->
                            <Button x:Name="btnAddMaster" Grid.Row="7" Content="➕ Добавить мастера" 
                                    Width="180" Height="40" HorizontalAlignment="Left"
                                    Background="#28a745" Foreground="White" FontWeight="Bold"
                                    Click="BtnAddMaster_Click" Margin="0,5,0,5"/>
                        </Grid>
                    </Border>

                    <!-- Список мастеров -->
                    <TextBlock Grid.Row="2" Text="Список мастеров" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                    <ListBox x:Name="lstMasters" Grid.Row="3" Margin="0,0,0,10" FontSize="13"
         DisplayMemberPath="DisplayText" SelectionMode="Single">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="10"/>
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="BorderBrush" Value="#ddd"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <!-- Кнопка деактивации -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnDeactivateMaster" Content="🔴 Деактивировать выбранного мастера" 
                                Width="230" Height="35" Background="#dc3545" Foreground="White"
                                Click="BtnDeactivateMaster_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            <!-- ВКЛАДКА 4: СПЕЦИАЛИЗАЦИЯ МАСТЕРОВ -->
            <TabItem Header="Специализация мастеров">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Выбор мастера -->
                    <TextBlock Text="Выберите мастера:" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <ComboBox x:Name="cmbMasterForSpecialization" Grid.Row="1" FontSize="14" Padding="8" 
                      Margin="0,0,0,15" SelectionChanged="CmbMasterForSpecialization_SelectionChanged"
                      DisplayMemberPath="DisplayText"/>

                    <!-- Текущие специализации -->
                    <Border Grid.Row="2" Background="#f8f9fa" BorderBrush="#ddd" BorderThickness="1" Padding="15" Margin="0,0,0,15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Текущие услуги мастера:" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                            <ListBox x:Name="lstCurrentSpecializations" Grid.Row="1" Height="200" FontSize="13"
                             DisplayMemberPath="DisplayText" SelectionMode="Single"/>

                            <Button x:Name="btnRemoveSpecialization" Grid.Row="2" Content="Удалить выбранную услугу" 
                            Width="200" Height="35" Margin="0,10,0,0" HorizontalAlignment="Left"
                            Background="#dc3545" Foreground="White" Click="BtnRemoveSpecialization_Click"/>
                        </Grid>
                    </Border>

                    <!-- Добавление новой специализации -->
                    <Border Grid.Row="3" Background="#f8f9fa" BorderBrush="#ddd" BorderThickness="1" Padding="15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Добавить новую услугу мастеру:" 
                               FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                            <ComboBox x:Name="cmbAvailableServices" Grid.Row="1" Grid.Column="0" FontSize="14" Padding="8" 
                              Margin="0,0,10,0" DisplayMemberPath="DisplayText"/>

                            <Button x:Name="btnAddSpecialization" Grid.Row="1" Grid.Column="1" Content="Добавить" 
                            Width="120" Height="35" Background="#28a745" Foreground="White"
                            Click="BtnAddSpecialization_Click"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        

        </TabControl>
        



        <!-- Кнопка выхода -->
        <Button Grid.Row="2" Content="🚪 Выход" Width="100" Height="35" 
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Background="#6c757d" Foreground="White" Click="BtnLogout_Click"/>
    </Grid>
</Window>