<Window x:Class="HairdresserSystemWPF.BookingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Запись на услугу" Height="550" Width="650"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Запись на услугу" FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="Услуга:" FontSize="14" Margin="0,5"/>
        <ComboBox x:Name="cmbService" Grid.Row="2" FontSize="14" Padding="8" Margin="0,5"
                  SelectionChanged="CmbService_SelectionChanged"/>

        <TextBlock Grid.Row="3" Text="Дата:" FontSize="14" Margin="0,15,0,5"/>
        <DatePicker x:Name="dpDate" Grid.Row="4" FontSize="14" Margin="0,5"
                    SelectedDateChanged="DpDate_SelectedDateChanged"/>

        <TextBlock Grid.Row="5" Text="Доступное время:" FontSize="14" Margin="0,15,0,5"/>
        <ListBox x:Name="lstSlots" Grid.Row="6" Height="200" Margin="0,5"
                 SelectionMode="Single"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,145,0,-105">
            <Button x:Name="btnConfirm" Content="Подтвердить запись" Width="150" Height="40" 
                    Background="#27ae60" Foreground="White" Click="BtnConfirm_Click"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="100" Height="40" 
                    Margin="15,0,0,0" Background="#e74c3c" Foreground="White"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
