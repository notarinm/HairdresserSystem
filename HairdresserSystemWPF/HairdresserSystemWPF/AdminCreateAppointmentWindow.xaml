<Window x:Class="HairdresserSystemWPF.AdminCreateAppointmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание записи для клиента" 
        Height="700" Width="750"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Стиль для заголовков секций -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2c3e50"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Стиль для блоков -->
        <Style x:Key="SectionBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#f8f9fa"/>
            <Setter Property="BorderBrush" Value="#dee2e6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <!-- Стиль для кнопок -->
        <Style TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- Стиль для текстовых полей -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="#ced4da"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="#ced4da"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock Grid.Row="0" Text="Создание записи для клиента" 
                       FontSize="22" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,20"
                       Foreground="#2c3e50"/>

            <!-- ================================================================ -->
            <!-- БЛОК 1: ПОИСК КЛИЕНТА -->
            <!-- ================================================================ -->
            <Border Grid.Row="1" Style="{StaticResource SectionBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="1. КЛИЕНТ" Style="{StaticResource SectionHeaderStyle}"/>

                    <!-- Поиск клиента -->
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Телефон:" VerticalAlignment="Center" FontSize="13"/>
                        <TextBox x:Name="txtClientPhone" Grid.Column="1" Margin="0,0,10,0"/>
                        <Button x:Name="btnFindClient" Grid.Column="2" Content="Найти клиента" 
                                Width="130" Background="#17a2b8" Foreground="White"
                                Click="BtnFindClient_Click"/>
                    </Grid>

                    <!-- Результат поиска - клиент найден -->
                    <Border x:Name="borderClientFound" Grid.Row="2" 
                            Background="#d4edda" BorderBrush="#c3e6cb" BorderThickness="1" 
                            Padding="10" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock x:Name="lblClientInfo" FontSize="13" FontWeight="Bold" Foreground="#155724"/>
                            <TextBlock x:Name="lblClientName" FontSize="12" Foreground="#155724" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Форма создания нового клиента -->
                    <Border x:Name="borderNewClient" Grid.Row="2" 
                            Background="#fff3cd" BorderBrush="#ffeeba" BorderThickness="1" 
                            Padding="10" Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Клиент не найден. Заполните данные:" 
                                       FontSize="12" Foreground="#856404" Margin="0,0,0,10"/>

                            <Grid Grid.Row="1" Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="ФИО:" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtNewClientName" Grid.Column="1"/>
                            </Grid>

                            <Grid Grid.Row="2" Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Email:" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtNewClientEmail" Grid.Column="1" Tag="необязательно"/>
                            </Grid>

                            <Grid Grid.Row="3" Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Логин:" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtNewClientLogin" Grid.Column="1" Margin="0,0,10,0"
                                         TextChanged="TxtNewClientLogin_TextChanged"/>
                                <TextBlock x:Name="lblLoginStatus" Grid.Column="2" FontSize="11" VerticalAlignment="Center"/>
                            </Grid>

                            <Grid Grid.Row="4" Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Пароль:" VerticalAlignment="Center"/>
                                <PasswordBox x:Name="txtNewClientPassword" Grid.Column="1"/>
                            </Grid>

                            <Button x:Name="btnCreateClient" Grid.Row="5" 
                                    Content="Зарегистрировать клиента" Width="200" Height="35"
                                    Margin="0,15,0,0" HorizontalAlignment="Left" 
                                    Background="#28a745" Foreground="White"
                                    Click="BtnCreateClient_Click"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- ================================================================ -->
            <!-- БЛОК 2: УСЛУГА И ДАТА -->
            <!-- ================================================================ -->
            <Border Grid.Row="2" Style="{StaticResource SectionBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="2. УСЛУГА И ДАТА" Style="{StaticResource SectionHeaderStyle}"/>

                    <Grid Grid.Row="1" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Услуга:" VerticalAlignment="Center"/>
                        <ComboBox x:Name="cmbService" Grid.Column="1" 
                                  SelectionChanged="CmbService_SelectionChanged"/>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Дата записи:" VerticalAlignment="Center"/>
                        <DatePicker x:Name="dpDate" Grid.Column="1" 
                                    SelectedDateChanged="DpDate_SelectedDateChanged"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- ================================================================ -->
            <!-- БЛОК 3: ВРЕМЯ -->
            <!-- ================================================================ -->
            <Border Grid.Row="3" Style="{StaticResource SectionBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="3. ВРЕМЯ" Style="{StaticResource SectionHeaderStyle}"/>

                    <ListBox x:Name="lstSlots" Grid.Row="1" Height="180" Margin="0,5"
                             SelectionMode="Single" FontSize="13">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="10"/>
                                <Setter Property="Margin" Value="0,3"/>
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="BorderBrush" Value="#dee2e6"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <!-- ================================================================ -->
            <!-- КНОПКИ ДЕЙСТВИЙ -->
            <!-- ================================================================ -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,20">
                <Button x:Name="btnConfirm" Content="Подтвердить запись" 
                        Width="180" Height="45" Background="#28a745" Foreground="White" 
                        FontSize="14" Click="BtnConfirm_Click"/>
                <Button x:Name="btnCancel" Content="Отмена" 
                        Width="120" Height="45" Margin="15,0,0,0" 
                        Background="#6c757d" Foreground="White" FontSize="14"
                        Click="BtnCancel_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>